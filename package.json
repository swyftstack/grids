{
  "name": "swyftgrid",
  "version": "0.1.0",
  "private": true,
  "description": "A modern, fast, beautiful open-source PostgreSQL client. The database client developers wish existed.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "pnpm --filter @swyftgrid/desktop dev",
    "dev:web": "pnpm --filter @swyftgrid/web dev",
    "build": "pnpm -r --filter \"./packages/*\" build && pnpm --filter @swyftgrid/desktop build",
    "build:web": "pnpm --filter @swyftgrid/web build",
    "tauri": "pnpm --filter @swyftgrid/desktop tauri",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.3.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.8.0"
  }
}
