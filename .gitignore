dist/
dist-ssr/
build/
out/
*.tsbuildinfo
# Vite caches & dep-optimizer / config timestamp files
.vite/
vite.config.ts.timestamp-*
vite.config.js.timestamp-*

# Tauri / Rust
apps/desktop/src-tauri/target/
**/target/
**/*.rs.bk
Cargo.lock.orig

# Local data / SQLite app store (incl. self-hosted auth + JSON stores)
*.sqlite
*.sqlite3
*.sqlite-wal
*.sqlite-shm
*.db
data/
apps/web/data/
swyftgrid.json
auth.sqlite

# Env & secrets
.env
.env.*
!.env.example

# SSH keys / certs — never commit credentials (referenced by path, not stored in-repo)
*.pem
*.key
*.ppk
id_rsa*
id_ed25519*
*_rsa
*_ed25519

# Editor / OS
.DS_Store
Thumbs.db
.idea/
.vscode/*
