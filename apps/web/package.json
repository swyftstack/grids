{
  "name": "@swyftgrid/web",
  "version": "0.1.0",
  "description": "Self-hosted web server for Swyftgrids — implements the IPC contract over HTTP and serves the UI.",
  "license": "MIT",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "cli": "node dist/cli.js",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.1",
    "@fastify/formbody": "^8.0.1",
    "@fastify/rate-limit": "^10.1.1",
    "@fastify/static": "^9.1.1",
    "@swyftgrid/core": "workspace:*",
    "bcryptjs": "^2.4.3",
    "fastify": "^5.0.0",
    "pg": "^8.13.0",
    "ssh2": "^1.16.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^25.9.3",
    "@types/pg": "^8.11.10",
    "@types/ssh2": "^1.15.1",
    "tsx": "^4.19.1",
    "typescript": "^6.0.3"
  }
}
